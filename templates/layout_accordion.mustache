{{!
    @template block_dash/layout_accordion

    Example context (json):
    {
        "sitefullname": "Moodle - 311",
        "courseurl": "https://localhost/moodle/course/view.php?id=2"
    }
}}
{{< block_dash/layout }}
    {{$body}}
        <div id="accordion-{{uniqueid}}" class="accordion-layout accordion-table-layout">
            {{#data.sections}}
                <div class="card">
                    <div class="card-header" id="heading-{{uniqueid}}-{{groupby}}">
                        <a href="javascript:void(0);">
                            <h5 class="mb-0 collapsed" {{datatoggle}}="collapse" {{datatarget}}="#collapse-{{uniqueid}}-{{groupby}}" aria-expanded="true" aria-controls="collapse-{{uniqueid}}-{{groupby}}">
                                {{{label}}}
                            </h5>
                        </a>
                    </div>

                    <div id="collapse-{{uniqueid}}-{{groupby}}" class="collapse" aria-labelledby="heading-{{uniqueid}}-{{groupby}}" {{dataparent}}="#accordion-{{uniqueid}}">
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table dash-table">
                                    <thead>
                                        <tr>
                                            {{#first_child.data}}
                                                {{#is_visible}}
                                                  <th>{{get_label}}</th>
                                                {{/is_visible}}
                                            {{/first_child.data}}
                                        </tr>
                                    </thead>
                                    <tbody>
                                    {{#rows}}
                                        <tr class="card-table" data-detailheader="{{detailheader}}" data-detailheading="{{detailheading}}"
                                            data-detailbody="{{detailbody}}" data-detailbody2="{{detailbody2}}"
                                            data-detailbody3="{{detailbody3}}" data-detailfooter="{{detailfooter}}"
                                            data-detailfooterright="{{detailfooterright}}"
                                            data-customcontent="{{customcontent}}">
                                            {{#data}}
                                                {{#is_visible}}
                                                  <td>{{{get_value}}}</td>
                                                {{/is_visible}}
                                            {{/data}}
                                        </tr>
                                    {{/rows}}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            {{/data.sections}}
        </div>
        {{#preferences.showdetailsarea}}
            {{#js}}
                require(['block_dash/details_area'], function(DetailsArea) {
                    DetailsArea.init('#accordion-{{uniqueid}}', {
                        detailsBgColor: '{{preferences.details_bg_color}}',
                        detailsTextColor: '{{preferences.details_text_color}}',
                        rowSelector: 'tbody tr[data-detailheader]',
                        mode: '{{preferences.details_area_mode}}',
                        detailsAreaSize: '{{preferences.details_area_size}}',
                        customContentHeight: '{{preferences.details_custom_content_height}}'
                    });
                });
            {{/js}}
        {{/preferences.showdetailsarea}}
    {{/body}}
{{/ block_dash/layout }}
