                        $(".card-layout-{{uniqueid}} .slick-slide").not($cardBlock.parents(".slick-slide")).removeClass("expand-slider-column");
                    }
                    $(".card-layout-{{uniqueid}} .slick-slide .card-block").not($cardBlock).removeClass("expand-details");
                    if (!$(".card-layout-{{uniqueid}} .slick-slide .card-block").hasClass('expand-details')) {
                        $cardBlock.closest('.layout_base').addClass("expand-card");
                    } else {
                        $cardBlock.closest('.layout_base').removeClass("expand-card");
                    }
                } else {
                    $(".card-layout-{{uniqueid}} > div.card-block").not($cardBlock).removeClass("expand-details");
                    if (!$(layoutClickHandler).hasClass('expand-details')) {
                        $cardBlock.closest('.layout_base').addClass("expand-card");
                    } else {
                        $cardBlock.closest('.layout_base').removeClass("expand-card");
                    }
                }
                // Check the fit-card or not.
                if ($cardBlock.closest('.layout_base').hasClass('fit-card')) {
                    $cardBlock.toggleClass('expand-details');
                    if ($cardBlock.hasClass('slider')) {
                        $cardBlock.parents(".slick-slide").toggleClass("expand-slider-column");
                        if ($(".card-layout-{{uniqueid}} .slick-slide .card-block").hasClass('expand-details')) {
                            $(".card-layout-{{uniqueid}} .slick-slide.slick-active").removeClass("slider-n-expand");
                        }
                        $cardBlock.parents(".slick-slide").prevAll(".slick-active").toggleClass('slider-n-expand');
                    } else {
                        if ($(layoutClickHandler).hasClass('expand-details')) {
                            $(".card-layout-{{uniqueid}} > div.card-block").removeClass("block-n-expand");
                        }
                        $cardBlock.prevAll().toggleClass('block-n-expand');
                    }
                    $(".card-layout-row.card-layout-{{uniqueid}}.expand-block .details-area-block").not($cardBlock.find(".details-area-block")).removeClass("show-detail");
                    $cardBlock.find(".card.details-area-block").toggleClass('show-detail');
                } else {
                    $cardBlock.toggleClass('expand-details');
                    if ($cardBlock.hasClass('slider')) {
                        $cardBlock.parents(".slick-slide").toggleClass("expand-slider-column");
                        $(".card-layout-row.card-layout-{{uniqueid}}.expand-block .details-area-block").not($cardBlock.find(".details-area-block")).removeClass("show-detail");
                        $cardBlock.find(".card.details-area-block").toggleClass('show-detail');
                    }  else {
                        {{#preferences.layout_default}}
                            $(".card-layout-row.card-layout-{{uniqueid}}.expand-block .details-area-block").not($cardBlock.next(".details-area-block")).removeClass("show-detail");
                            $cardBlock.next(".card.details-area-block").toggleClass('show-detail');
                        {{/preferences.layout_default}}
                    }

                    if ($cardBlock.hasClass('masonry')) {
                        {{#preferences.layout_masonry}}
                            $(".card-layout-row.card-layout-{{uniqueid}}.expand-block .details-area-block").not($cardBlock.find(".details-area-block")).removeClass("show-detail");
                            $cardBlock.find(".card.details-area-block").toggleClass('show-detail');
                        {{/preferences.layout_masonry}}
                    }
                }

                {{#preferences.layout_masonry}}
                if (iso_{{uniqueid}}) {
                    setTimeout(function() {
                        iso_{{uniqueid}}.arrange();
                    }, 150);
                    setTimeout(function() {
                        iso_{{uniqueid}}.arrange();
                    }, 300);
                    setTimeout(function() {
                        iso_{{uniqueid}}.arrange();
                    }, 500);
                }
                {{/preferences.layout_masonry}}
            {{/preferences.detailareaexpand}}
            {{#preferences.detailareamodal}}
                var templatecontext = {
                    detailheader: $cardBlock.find(".card-info").attr('data-detailheader'),
                    detailheading: $cardBlock.find(".card-info").attr('data-detailheading'),
                    detailbody: $cardBlock.find(".card-info").attr('data-detailbody'),
                    detailbody2: $cardBlock.find(".card-info").attr('data-detailbody2'),
                    detailbody3: $cardBlock.find(".card-info").attr('data-detailbody3'),
                    detailfooter: $cardBlock.find(".card-info").attr('data-detailfooter'),
                    detailfooterright: $cardBlock.find(".card-info").attr('data-detailfooterright'),
                    customcontent: $cardBlock.find(".card-info").attr('data-customcontent') || '',
                    details_bg_color: "{{preferences.details_bg_color}}",
                    details_text_color: "{{preferences.details_text_color}}",
                    detailmodal: "true"
                };
                Modal.create({
                    title: Str.get_string('strinfo', 'block_dash'),
                    type: Modal.types.CANCEL,
                    body: Templates.render('block_dash/layouts_cards_detailarea', templatecontext),
                    large: true,
                }).then(modal => {
                    modal.show();
                    modal.getRoot().on(ModalEvents.hidden, function() {
                        modal.destroy();
                    }).catch(Notification.exception);
                    return modal;
                });
            {{/preferences.detailareamodal}}

            // Update URL hash to the detail-id so the URL is shareable.
            {{#preferences.showdetailsarea}}
                var detailId = $(this).attr('data-detail-id');
                if (detailId && window.history && window.history.replaceState) {
                    window.history.replaceState(null, '', '#' + detailId);
                }
            {{/preferences.showdetailsarea}}
        });
        {{#preferences.layout_slider}}
            var sliderClass = ".card_layout_slider.slider-{{uniqueid}}";
            $(sliderClass).slick(
                {
                    infinite: true,
                    slidesToShow: {{preferences.slidesToShow}},
                    slidesToScroll: {{preferences.slidesToScroll}},
                    autoplay: {{preferences.autoplay}},
                    autoplaySpeed: {{preferences.autoplaySpeed}},
                    arrows: {{preferences.arrows}},
                    prevArrow: '<button class="slick-prev" type="button" aria-label="{{#str}}previous, core{{/str}}">{{#str}}previous, core{{/str}}</button>',
                    nextArrow: '<button class="slick-next" type="button" aria-label="{{#str}}next, core{{/str}}">{{#str}}next, core{{/str}}</button>',
                    centerMode: {{preferences.centerMode}},
                    centerPadding: '{{preferences.centerPadding}}px',
                    dots: {{preferences.dots}},
                    draggable: {{preferences.draggable}},
                    fade: {{preferences.fade}},
                    infinite: {{preferences.infinite}},
                    rows: {{preferences.rows}},
                    slidesPerRow: {{preferences.slidesPerRow}},
                    speed: {{preferences.speed}},
                    swipeToSlide: {{preferences.swipeToSlide}},
                    variableWidth: {{preferences.variableWidth}},
                    vertical: {{preferences.vertical}},
                    verticalSwiping: {{preferences.verticalSwiping}},
                    responsive: [
                        {
                        breakpoint: 1024,
                        settings: {
                            slidesToShow: 3,
                            slidesToScroll: 3,
                            infinite: true,
                            dots: true
                        }
                        },
                        {
                        breakpoint: 600,
                        settings: {
                            slidesToShow: 2,
                            slidesToScroll: 2
                        }
                        },
                        {
                        breakpoint: 480,
                        settings: {
                            slidesToShow: 1,
                            slidesToScroll: 1
                        }
                        }
                    ]
                }
            );
        {{/preferences.layout_slider}}
        {{#preferences.layout_default}}
            require(['block_dash/cards_filter_sort'], function(CardsFilterSort) {
                CardsFilterSort.init('{{uniqueid}}');
            });
        {{/preferences.layout_default}}
        {{#preferences.layout_slider}}
            require(['block_dash/cards_filter_sort'], function(CardsFilterSort) {
                CardsFilterSort.init('{{uniqueid}}');
            });
        {{/preferences.layout_slider}}
        {{#preferences.layout_masonry}}
            $('.card_layout_masonry .card-block .masonry-more a').click(function(){
                $(this).closest('.card-block').toggleClass('show-content');
            });
        {{/preferences.layout_masonry}}
    });

    {{#preferences.showdetailsarea}}
        // Initialise hash-based auto-open so shared URLs with #dash-detail-... fragments work.
        require(['block_dash/details_area'], function(DetailsArea) {
            DetailsArea.hashInit();
        });
    {{/preferences.showdetailsarea}}
});
{{/js}}
