{{#preferences.layout_masonry}}
<script src="{{config.wwwroot}}/blocks/dash/js/isotope.js"></script>
<script>
    var qsRegex;
    var grid = document.querySelector( '.card-layout-{{uniqueid}}' + '.card_layout_masonry');
    var iso_{{uniqueid}} = new Isotope( grid, {
        itemSelector: '.filtr-item',
        masonry: {
            columnWidth: 10
        },
        filter: function(element) {
            if (element == 0 || element == null) {
                element = this;
            }
            var text = element.textContent || element.innerText;
            return (qsRegex && text != undefined) ? text.match(qsRegex) : true;
        },
        getSortData: {
            number: '[data-recordid]',
        }
    });

    var buttons = document.querySelectorAll('.masonry-sorter-{{uniqueid}} button');
    var val = grid.closest(".masonry-sorter-{{uniqueid}} button");
    var ascButton = document.querySelectorAll(".masonry-sorter-{{uniqueid}} button.asc")[0];
    var descButton = document.querySelectorAll(".masonry-sorter-{{uniqueid}} button.desc")[0];
    buttons.forEach(function(button) {
        button.addEventListener('click', function() {
            ascButton.classList.remove('active');
            descButton.classList.remove('active');
            //button.previousElementSibling.classList.remove
            button.classList.add('active');
            / Get the element name to sort /
            var sortValue = button.getAttribute('data-sort-value');

            / Get the sorting direction: asc||desc /
            var sortDirection = button.getAttribute('data-sort-direction');

            / convert it to a boolean /
            sortDirection = sortDirection == 'asc';

            / pass it to isotope /
            iso_{{uniqueid}}.arrange({ sortBy: sortValue, sortAscending: sortDirection });
        });
    });

    // use value of search field to filter
    var quicksearch = document.querySelector('.masonry-quicksearch-{{uniqueid}}');
    if (quicksearch) {
        // use value of search field to filter
        quicksearch.addEventListener('keyup', debounce(function() {
        qsRegex = new RegExp(quicksearch.value, 'gi');
            iso_{{uniqueid}}.arrange();
        }, 200));
    }

    var masonryMore = grid.querySelectorAll(".filtr-item .masonry-more");
    if (masonryMore) {
        masonryMore.forEach(function(moreItem) {
            moreItem.addEventListener('click', function() {
                iso_{{uniqueid}}.arrange();
            });
        });
    }

    // debounce so filtering doesn't happen every millisecond
    function debounce(fn, threshold) {
        var timeout;
        threshold = threshold || 100;
        return function debounced() {
            clearTimeout(timeout);
            var args = arguments;
            var _this = this;
            function delayed() {
            fn.apply(_this, args);
            }
            timeout = setTimeout(delayed, threshold);
        };
    }

</script>

