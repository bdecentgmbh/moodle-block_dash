    {{/preferences.layout_default}}

    $(document).ready(function() {
        {{#preferences.detailareafloating}}
            var floatingParent = ".dash-block-content .card-layout-row.card-layout-{{uniqueid}}";
            var floatingHideTimeout = null;
            var floatingShowTimeout = null;
            var floatingCurrentBlock = null;
            var floatingPendingBlock = null;
            var floatingIsVisible = false;

            // Timing configuration (in milliseconds).
            var SHOW_DELAY = 180;   // Delay before showing (prevents accidental triggers).
            var HIDE_DELAY = 350;   // Delay before hiding (allows mouse to move to panel).

            /**
             * Hide ALL floating details in this layout - ensures only one is ever visible.
             */
            function hideAllFloatingDetails() {
                // Remove all floating-details classes from all blocks.
                $(".card-layout-{{uniqueid}} .card-block").removeClass("floating-details");
                // Remove all show-detail classes from all details panels.
                $(".card-layout-{{uniqueid}} .details-area-block").removeClass("show-detail");
                // Remove related layout classes.
                $(".card-layout-{{uniqueid}} .card-block").removeClass("block-n-float");
                $(".card-layout-{{uniqueid}} .slick-slide").removeClass("float-slider-column slider-n-float");
                $(".card-layout-{{uniqueid}}").removeClass("floating-card");
            }

            /**
             * Actually show floating details for a card block (internal).
             */
            function doShowFloatingDetails($cardBlock) {
                // If already showing for this block, nothing to do.
                if (floatingCurrentBlock === $cardBlock[0] && floatingIsVisible) {
                    return;
                }

                // ALWAYS hide ALL other details first - ensures only one visible at a time.
                hideAllFloatingDetails();

                floatingCurrentBlock = $cardBlock[0];
                floatingIsVisible = true;

                $cardBlock.closest('.layout_base').addClass("floating-card");

                if ($cardBlock.closest('.layout_base').hasClass('fit-card')) {
                    $cardBlock.addClass('floating-details');
                    if ($cardBlock.hasClass('slider')) {
                        $cardBlock.parents(".slick-slide").addClass("float-slider-column");
                        $cardBlock.parents(".slick-slide").prevAll(".slick-active").addClass('slider-n-float');
                    } else {
                        $cardBlock.prevAll(".card-block").addClass('block-n-float');
                    }
                    $cardBlock.find(".card.details-area-block").addClass('show-detail');
                } else {
                    $cardBlock.addClass('floating-details');
                    if ($cardBlock.hasClass('slider')) {
                        $cardBlock.find(".card.details-area-block").addClass('show-detail');
                    } else {
                        {{#preferences.layout_default}}
                            $cardBlock.next(".card.details-area-block").addClass('show-detail');
                        {{/preferences.layout_default}}
                    }

                    if ($cardBlock.hasClass('masonry')) {
                        {{#preferences.layout_masonry}}
                            $cardBlock.find(".card.details-area-block").addClass('show-detail');
                        {{/preferences.layout_masonry}}
                    }
                }
            }

            /**
             * Actually hide floating details (internal).
             */
            function doHideFloatingDetails() {
                // Use the cleanup function to ensure ALL details are hidden.
                hideAllFloatingDetails();
                floatingCurrentBlock = null;
                floatingIsVisible = false;
            }

            /**
             * Schedule showing with a small delay (debounce rapid movements).
             */
            function scheduleFloatingShow($cardBlock) {
                // Cancel any pending hide.
                clearTimeout(floatingHideTimeout);

                // If already showing this block, nothing to do.
                if (floatingCurrentBlock === $cardBlock[0] && floatingIsVisible) {
                    return;
                }

                // Immediately hide any other visible block so two panels are never shown at once.
                if (floatingIsVisible && floatingCurrentBlock && floatingCurrentBlock !== $cardBlock[0]) {
                    hideAllFloatingDetails();
                    floatingCurrentBlock = null;
                    floatingIsVisible = false;
                }

                // If already pending show for same block, nothing to do.
                if (floatingPendingBlock === $cardBlock[0]) {
                    return;
                }

                // Cancel any previous pending show.
                clearTimeout(floatingShowTimeout);
                floatingPendingBlock = $cardBlock[0];

                floatingShowTimeout = setTimeout(function() {
                    // Only show if this block is still the pending one.
                    if (floatingPendingBlock === $cardBlock[0]) {
                        doShowFloatingDetails($cardBlock);
                        floatingPendingBlock = null;
                    }
                }, SHOW_DELAY);
            }

            /**
             * Schedule hide with delay to allow mouse to move to panel.
             */
            function scheduleFloatingHide() {
                // Cancel any pending show.
                clearTimeout(floatingShowTimeout);
                floatingPendingBlock = null;

                // Cancel any existing hide timeout.
                clearTimeout(floatingHideTimeout);

                floatingHideTimeout = setTimeout(function() {
                    doHideFloatingDetails();
                }, HIDE_DELAY);
            }

            /**
             * Cancel all pending show/hide operations.
             */
            function cancelAllFloatingTimeouts() {
                clearTimeout(floatingShowTimeout);
                clearTimeout(floatingHideTimeout);
                floatingPendingBlock = null;
            }

            /**
             * Check if element is part of the current floating details (trigger or panel).
             */
            function isPartOfCurrentFloating(element) {
                if (!element) {
                    return false;
                }
                // Check against current block.
                if (floatingCurrentBlock) {
                    var $cardBlock = $(floatingCurrentBlock);
                    if ($cardBlock[0] === element || $.contains($cardBlock[0], element)) {
                        return true;
                    }
                    var $detailsPanel = $cardBlock.find(".details-area-block").add($cardBlock.next(".details-area-block"));
                    for (var i = 0; i < $detailsPanel.length; i++) {
                        if ($detailsPanel[i] === element || $.contains($detailsPanel[i], element)) {
                            return true;
                        }
                    }
                }
                // Check against pending block.
                if (floatingPendingBlock) {
                    var $pendingBlock = $(floatingPendingBlock);
                    if ($pendingBlock[0] === element || $.contains($pendingBlock[0], element)) {
                        return true;
                    }
                }
                return false;
            }

            // Mouseenter on trigger - schedule show with delay.
            $(floatingParent).on('mouseenter', '[data-action="open-details-modal"]', function() {
                cancelAllFloatingTimeouts();
                var $cardBlock = $(this).closest('.card-block');
                scheduleFloatingShow($cardBlock);
            });

            // Mouseleave on trigger - schedule hide unless moving to the panel.
            $(floatingParent).on('mouseleave', '[data-action="open-details-modal"]', function(e) {
                if (isPartOfCurrentFloating(e.relatedTarget)) {
                    return;
                }
                scheduleFloatingHide();
            });

            // Mouseenter on details panel - cancel any pending hide.
            $(floatingParent).on('mouseenter', '.details-area-block', function() {
                cancelAllFloatingTimeouts();
            });

            // Mouseleave on details panel - schedule hide unless moving to trigger.
            $(floatingParent).on('mouseleave', '.details-area-block', function(e) {
                if (isPartOfCurrentFloating(e.relatedTarget)) {
                    return;
                }
                scheduleFloatingHide();
            });

            // Also bind to card-block for better coverage.
            $(floatingParent).on('mouseenter', '.card-block.floating-details', function() {
                cancelAllFloatingTimeouts();
            });

            $(floatingParent).on('mouseleave', '.card-block.floating-details', function(e) {
                if (isPartOfCurrentFloating(e.relatedTarget)) {
                    return;
                }
                scheduleFloatingHide();
            });
        {{/preferences.detailareafloating}}
