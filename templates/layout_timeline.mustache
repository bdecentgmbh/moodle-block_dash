{{!
    @template block_dash/layout_timeline

    Example context (json):
    {
        "sitefullname": "Moodle - 311",
        "courseurl": "https://localhost/moodle/course/view.php?id=2"
    }
}}
{{< block_dash/layout }}
    {{$body}}
        <div class="container timeline-layout" id="dash-timeline-{{uniqueid}}">
            <ul class="timeline">
                {{#data.rows}}
                    <li class="timeline-inverted"
                        data-detailheader="{{detailheader}}" data-detailheading="{{detailheading}}"
                        data-detailbody="{{detailbody}}" data-detailbody2="{{detailbody2}}"
                        data-detailbody3="{{detailbody3}}" data-detailfooter="{{detailfooter}}"
                        data-detailfooterright="{{detailfooterright}}"
                        data-customcontent="{{customcontent}}">
                            <div class="timeline-info floating-details-show">
                                <div class="timeline-badge {{badgecolor}}">{{{icon}}}</div>
                                <div class="timeline-panel">
                                    {{#imageurl}}
                                        <img class="float-right" src="{{imageurl}}" role="presentation">
                                    {{/imageurl}}
                                    <div class="timeline-heading">
                                        <small class="text-muted">{{#preferences.subheadingfield_icon}}{{{preferences.subheadingfield_icon}}}{{/preferences.subheadingfield_icon}}{{subheading}}</small>
                                        <h4 class="timeline-title"> {{{heading}}}</h4>
                                    </div>
                                    <div class="timeline-body">
                                        <p>{{{body}}}</p>
                                        <p>{{{body2}}}</p>
                                        <p>{{{body3}}}</p>
                                    </div>
                                </div>
                            </div>
                    </li>
                {{/data.rows}}
            </ul>
        </div>
        {{#preferences.showdetailsarea}}
            {{#js}}
                require(['block_dash/details_area'], function(DetailsArea) {
                    DetailsArea.init('#dash-timeline-{{uniqueid}}', {
                        detailsBgColor: '{{preferences.details_bg_color}}',
                        detailsTextColor: '{{preferences.details_text_color}}',
                        rowSelector: 'li.timeline-inverted[data-detailheader]',
                        mode: '{{preferences.details_area_mode}}',
                        detailsAreaSize: '{{preferences.details_area_size}}',
                        customContentHeight: '{{preferences.details_custom_content_height}}'
                    });
                });
            {{/js}}
        {{/preferences.showdetailsarea}}
    {{/body}}
{{/ block_dash/layout }}
